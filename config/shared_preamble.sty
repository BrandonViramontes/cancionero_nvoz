%   \large  %\normalsize
% }


\renewcommand{\chorusfont}{\bfseries}


% --- Numeración --- 
\newcommand{\songsectionletter}{} % Macro para guardar la letra de la sección (A, B, C...)
\renewcommand{\thesongnum}{\songsectionletter\arabic{songnum}} % Redefinición del formato de numeración 




%%% BLOQUES CONDICIONALES %%%

%% MOSTRAR ENCABEZADOS DE SECCIONES ( EL ENCABEZADO AÑADE SALTOS DE PAGINA EN LA VERSION ESQUEMA, POR LO QUE SE RECOMIENDA MANTENERLO DESHABILITADO EN DICHA VERSION ) %%%
\newif\ifheader
\headertrue % (True (default) → mostrar saltos de página)

%% MOSTRAR LINKS DE CONSULTA EMBEBIDOS EN CANCIONES 
\newif\iflink
\linktrue % (True (default) → Mostrar Links)

%% MOSTRAR SUBDIVISIONES EN LAS SECCIONES
\newif\ifsubheader
\subheadertrue % (True (default) → mostrar subdivisiones)

%% MOSTRAR TABLATURAS DE ACORDES
\newif\ifgtabs
\gtabstrue % (True (default) → mostrar tablas de acordes)

%% ETIQUETAS DE TIEMPO LITÚRGICO Y MOMENTO DE LA CELEBRACIÓN
\newif\iflabel
\labeltrue % (True (default) → mostrar etiquetas de tiempo litúrgico y momento)

%% MOSTRAR ACORDES COMPLETOS DE LAS CANCIONES
\newif\ifnofullchords
\nofullchordstrue % (True (default) → No mostrar acordes completos)


%% HEADER DE SECCIONES %%%
\newcommand{\sectionheader}[1]{
    \ifheader
        \sclearpage
        \sepindexesfalse
        \songsection{#1}
        \hrule \vspace{0.5cm}
    \fi
}

%% Tiempos liturgicos
\newcommand{\tiempoliturgico}[1]{{\noindent\scriptsize\textit{\textbf{Tiempo:} #1}}}
\newcommand{\uso}[1]{{\noindent\scriptsize\textit{\textbf{Uso:} #1}}}
\newcommand{\celebracion}[1]{{\noindent\scriptsize\textit{\textbf{Celebración:} #1}}}


